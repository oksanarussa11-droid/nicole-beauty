{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "if [ \"$SITE\" = \"pro\" ]; then cp register.html index.html && echo 'pro site: register.html copied to index.html'; else echo 'admin site: no swap'; fi",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
